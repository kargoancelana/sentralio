APP_PORT=3000

# Environment (development | production)
NODE_ENV=development

# Frontend URL for CORS (production only)
# Example: https://wms.yourdomain.com
FRONTEND_URL=

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=wms_sync

# Shopee API
PARTNER_ID=your_partner_id
PARTNER_KEY=your_partner_key
SHOP_ID=your_shop_id
ACCESS_TOKEN=your_access_token
REFRESH_TOKEN=your_refresh_token

# Encryption Key (MUST be exactly 32 bytes / 64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET_KEY=your_32_byte_secret_key_here_64_hex_chars

# Shopee OAuth Redirect URL
SHOPEE_REDIRECT_URL=https://google.com

# Custom Label - Sender Info (for PENGIRIM section on label)
SHOP_NAME=Nama Toko Anda
SHOP_PHONE=0821-9876-5432
SHOP_CITY=Jakarta
