APP_PORT=3000

# Environment (development | production)
NODE_ENV=development

# Frontend URL for CORS (production only)
# Example: https://wms.yourdomain.com
FRONTEND_URL=

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=sentralio

# ─── Shopee partner app ───────────────────────────────────────
# For LOCAL APP BOOT ONLY, placeholder values are acceptable as long as:
# - PARTNER_ID stays numeric
# - PARTNER_KEY is non-empty
# - you understand live Shopee OAuth will NOT work with placeholders
#
# For LIVE SHOPEE TESTING, replace all three values below with real credentials
# from Shopee Open Platform and a real registered redirect URL.
PARTNER_ID=123456
PARTNER_KEY=replace_me_for_local_boot_or_real_partner_key
SHOPEE_REDIRECT_URL=https://example.com/shopee/callback

# ─── Shopee per-shop tokens (OPTIONAL) ───────────────────────
# Leave these BLANK on a fresh install. You obtain them automatically by
# authorizing a shop in the web app (Settings → Integrasi Toko); they are then
# stored and auto-refreshed in the `shopee_credentials` table. Only fill them in
# if you want `bun run db:seed` to preseed a shop manually.
SHOP_ID=
ACCESS_TOKEN=
REFRESH_TOKEN=

# Encryption Key (MUST be exactly 32 bytes / 64 hex characters)
# Generate with Bun:   bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or with OpenSSL:     openssl rand -hex 32
TOKEN_SECRET_KEY=your_32_byte_secret_key_here_64_hex_chars

# Custom Label - Sender Info (for PENGIRIM section on label)
SHOP_NAME=Nama Toko Anda
SHOP_PHONE=0821-9876-5432
SHOP_CITY=Jakarta

# ─── Authentication ──────────────────────────────────────────
# JWT signing secret — MUST be at least 32 UTF-8 bytes.
# Generate with Bun:   bun -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Or with OpenSSL:     openssl rand -hex 48
AUTH_JWT_SECRET=replace_with_a_secret_at_least_32_bytes_long
# Comma-separated list of allowed origins for CSRF protection.
# Keep this aligned with your frontend dev origin. Default Vite dev server here is 5175.
AUTH_ALLOWED_ORIGINS=http://localhost:5175,http://localhost:3000

# ─── Redis (BullMQ Queue) ────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
